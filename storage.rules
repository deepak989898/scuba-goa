rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null
        && firestore.exists(
          /databases/(default)/documents/admins/$(request.auth.uid)
        );
    }

    // Service media uploads from admin panel
    match /services/{serviceSlug}/{mediaType}/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Homepage hero slider (posters + videos) from admin panel
    match /hero/{kind}/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
