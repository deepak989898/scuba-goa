# Site
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Marketing & analytics (optional; leave unset to disable) ---
# Google Analytics 4 — Reports: users, geography, device, traffic acquisition.
# Create a GA4 property → Admin → Data streams → Web → copy Measurement ID (G-XXXXXXXXXX).
# You can use the same ID as Firebase Analytics below, or set only NEXT_PUBLIC_GA_MEASUREMENT_ID.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity — Session recordings, click maps, heatmaps (clarity.microsoft.com → your project ID).
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Google Search Console — pick ONE verification approach:
#
# A) HTML tag (matches this app): Search Console → URL prefix property → Verify ownership →
#    "HTML tag" → copy only the content value inside content="..." → set below → deploy.
#    Next.js injects <meta name="google-site-verification" content="..."> via src/app/layout.tsx.
#
# B) HTML file: If you chose "HTML file" in Search Console, Google expects a file at
#    https://YOUR-DOMAIN/<exact-filename>.html — place that file in the repo folder `public/`
#    (same name Google gave you, e.g. google123abc.html), commit, deploy, then click Verify.
#    Do not use this env for method B.
#
# Keywords, impressions, and clicks are viewed in the Search Console UI after verification.
GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_WHATSAPP_NUMBER=919217290871
NEXT_PUBLIC_CONTACT_EMAIL=support@bookscubagoa.com

# Optional: MP3/WebM/OGG URL for hero when a video has no audio track (Safari) or when admin enables “Site music” on a slide.
NEXT_PUBLIC_HERO_FALLBACK_MUSIC_URL=

# Firebase client (public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (server only) — JSON on one line, escape quotes in private_key newlines as \n
# Enables seeding, admin APIs, and /api/admin/hero-media-upload (bypasses Storage CORS for uploads).
# Large hero videos may still need storage.cors.json on the bucket (repo root) if server upload hits size limits.
FIREBASE_SERVICE_ACCOUNT_KEY=

# Razorpay — THREE vars. Dashboard gives "Key ID" + "Key Secret".
# Paste Key ID in BOTH lines below (same value twice). Paste Secret only in RAZORPAY_KEY_SECRET.
# See docs/RAZORPAY-TEST.md and docs/DEPLOY-VERCEL.md
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_or_live_key_id
RAZORPAY_KEY_ID=rzp_test_or_live_key_id
RAZORPAY_KEY_SECRET=key_secret_not_key_id

# Resend — booking emails after Razorpay verify (server-only)
RESEND_API_KEY=
# Verified sender, e.g. support@bookscubagoa.com (domain must be verified in Resend)
RESEND_FROM_EMAIL=
# Inbox for staff “new booking” alerts (defaults to NEXT_PUBLIC_CONTACT_EMAIL if unset)
BOOKING_ADMIN_NOTIFY_EMAIL=support@bookscubagoa.com
# Optional: extra BCC on customer confirmation only
ADMIN_NOTIFY_EMAIL=

# OpenAI — optional; powers "AI Help" via /api/chat (server-only, never commit real keys)
OPENAI_API_KEY=
