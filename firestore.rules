rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /packages/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    /** Promo codes for online checkout; public read, admin write. */
    match /offers/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    match /services/{slug} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    match /heroSlides/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    match /homeGallery/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    match /bookings/{id} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow write: if false;
    }
    /** Written by server (Admin SDK) via /api/marketing/lead; admin UI reads & updates follow-up flags. */
    match /marketingLeads/{id} {
      allow read, update: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow create, delete: if false;
    }
    match /pageViews/{id} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow write: if false;
    }
    match /analyticsSessions/{id} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow write: if false;
    }
    match /ratings/{id} {
      allow read: if resource.data.approved == true
        || (request.auth != null
          && exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      allow create: if false;
      allow update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
